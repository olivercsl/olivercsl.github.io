---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import { Hero } from '../components/Hero';
import { LogoStrip } from '../components/LogoStrip';
import { AudienceDoors } from '../components/AudienceDoors';
import { ProofSection } from '../components/ProofSection';
import { FeatureSection } from '../components/FeatureSection';
import { ProcessSection } from '../components/ProcessSection';
import { TrustSection } from '../components/TrustSection';
import { AlsoAvailable } from '../components/AlsoAvailable';
import { ContactSection } from '../components/ContactSection';

// Organization identity for search engines: name, logo, offices, and the
// verifiable AWS partner listing as sameAs. Facts only.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://cloudzeta.solutions/#org',
  name: 'Cloudzeta Solutions',
  url: 'https://cloudzeta.solutions',
  logo: 'https://cloudzeta.solutions/logo-circuit.svg',
  description:
    'AWS Advanced Partner building and running cloud infrastructure, with accelerated network routes into mainland China for fintech and finance platforms.',
  email: 'info@cloudzeta.solutions',
  sameAs: [
    'https://partners.amazonaws.com/partners/0018W00002IkfioQAB/Cloudzeta%20Solutions%20Limited',
  ],
  location: [
    { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'Sydney', addressCountry: 'AU' } },
    { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'Hong Kong', addressCountry: 'HK' } },
  ],
};
---

<Layout
    title="AWS Advanced Partner & China Connectivity | Cloudzeta"
    description="AWS built and run by an Advanced Partner, with website and MetaTrader 4/5 acceleration into mainland China. Trusted by global fintech and finance brands."
>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />
    <Navbar client:load />
	<main>
		<Hero client:load />
        <LogoStrip client:visible />
        <AudienceDoors client:visible />
        <ProofSection client:visible />
        <FeatureSection client:visible />
        <ProcessSection client:visible />
        <TrustSection client:visible />
        <AlsoAvailable client:visible />
        <ContactSection client:visible />
	</main>
</Layout>
