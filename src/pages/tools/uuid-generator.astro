---
/**
 * ============================================================================
 *  DO NOT ADD ANALYTICS, ADS, OR THIRD-PARTY SCRIPTS TO THIS PAGE.
 * ============================================================================
 *  Same commitment as the other tools: no ads, no trackers, works offline.
 *  Any external script makes those published claims false.
 * ============================================================================
 */
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { UuidGenerator } from '../../components/tools/UuidGenerator';

const faqs = [
  {
    q: 'What is a UUID?',
    a: 'A UUID (Universally Unique Identifier), also called a GUID, is a 128-bit value written as 32 hexadecimal digits in the pattern 8-4-4-4-12. It is designed so that anyone can generate one independently with a negligible chance of collision, which makes it useful for database keys, request IDs, and file names.',
  },
  {
    q: 'Which version should I use?',
    a: 'Use v4 unless you have a reason not to: it is random and has no structure to leak. Use v7 when you want identifiers that sort in creation order, which keeps database indexes efficient; it embeds a millisecond timestamp at the front. v1 is a legacy timestamp format kept for compatibility. The nil UUID is all zeros, used as a placeholder or "none" value.',
  },
  {
    q: 'Are these UUIDs safe to use?',
    a: 'Yes. They are generated in your browser with crypto.getRandomValues, the same cryptographically secure source used for TLS keys, and nothing is sent to a server. You can confirm this in your browser network tab, or by disconnecting from the internet: the tool keeps working.',
  },
  {
    q: 'Can I generate many at once?',
    a: 'Yes, up to 100 at a time. Copy them individually or use "Copy all" to put the whole batch on your clipboard, one per line. For v7 and v1 the batch is generated in order, so the identifiers sort the way they were created.',
  },
  {
    q: 'Is a UUID guaranteed to be unique?',
    a: 'Not guaranteed, but the odds of a collision are vanishingly small. A v4 UUID has 122 random bits; you would need to generate billions per second for many years before a duplicate became likely. For virtually every application they can be treated as unique.',
  },
  {
    q: 'Are there ads or tracking here?',
    a: 'No. No ads, no trackers, no analytics, and no account. Most free UUID sites are funded by ads that load the moment you click generate; this one is a plain static page that asks nothing of you.',
  },
];

const pageUrl = 'https://cloudzeta.solutions/tools/uuid-generator';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}#app`,
      name: 'Cloudzeta UUID Generator',
      url: pageUrl,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any modern web browser',
      description:
        'Free UUID / GUID generator. Create v4, v7, v1 and nil UUIDs in bulk, with formatting options. Runs client-side, no ads, no tracking.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: [
        'UUID versions 4, 7, 1 and nil',
        'Generate up to 100 at once',
        'Uppercase, no-hyphen and brace formatting',
        'Cryptographically secure randomness',
        'Runs offline. Nothing is sent to a server',
      ],
      publisher: { '@type': 'Organization', name: 'Cloudzeta Solutions', url: 'https://cloudzeta.solutions' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cloudzeta.solutions' },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://cloudzeta.solutions/tools' },
        { '@type': 'ListItem', position: 3, name: 'UUID Generator', item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title="UUID Generator | v4, v7, v1 & Nil GUIDs, No Ads | Cloudzeta"
  description="Free UUID / GUID generator. Create v4, v7, v1 and nil UUIDs in bulk with formatting options. Runs entirely in your browser. No ads, no tracking, works offline."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navbar minimal client:load />

  <main>
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 px-4 sm:px-6 bg-[radial-gradient(78%_120%_at_50%_-8%,#eef5ff_0%,#ffffff_58%)]">
      <div class="max-w-5xl mx-auto text-center mb-6 md:mb-7">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-tx-primary leading-[1.08]">
          UUID Generator
        </h1>
      </div>

      <div class="max-w-2xl mx-auto">
        <UuidGenerator client:load />
        <p class="text-base text-tx-secondary text-center text-balance mt-6">
          v4, v7, v1 and nil UUIDs, generated in your browser. No ads, no tracking.
        </p>
      </div>
    </section>

    <!-- Versions explainer -->
    <section class="py-24 px-6 border-t border-glass-border">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-4 text-center">
          Which UUID version do you need?
        </h2>
        <p class="text-xl text-tx-secondary text-center mb-14 max-w-2xl mx-auto">
          When in doubt, use v4. Reach for v7 when order matters.
        </p>

        <div class="grid sm:grid-cols-2 gap-6">
          {
            [
              { t: 'v4 · Random', d: 'The everyday default. 122 random bits, no embedded structure, nothing to leak. Use it for keys, request IDs and file names unless you specifically need ordering.' },
              { t: 'v7 · Time-ordered', d: 'A millisecond timestamp at the front means these sort in creation order, which keeps database indexes tight instead of fragmenting. The modern choice for primary keys.' },
              { t: 'v1 · Timestamp based', d: 'A legacy format combining a timestamp and a node id. We use a random node rather than your hardware address. Generate it for compatibility with older systems.' },
              { t: 'Nil · All zeros', d: 'The special 00000000-0000-0000-0000-000000000000 value, used as a placeholder or an explicit "no identifier yet".' },
            ].map((v) => (
              <div class="bg-white p-7 rounded-2xl border border-glass-border shadow-sm">
                <h3 class="text-lg font-semibold text-tx-primary mb-2">{v.t}</h3>
                <p class="text-tx-secondary leading-relaxed">{v.d}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6 bg-surface border-t border-glass-border">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-12 text-center">
          UUID generator FAQs
        </h2>
        <div class="space-y-3">
          {
            faqs.map((faq) => (
              <details class="group bg-white border border-glass-border rounded-2xl overflow-hidden shadow-sm">
                <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 font-semibold text-tx-primary list-none hover:text-accent transition-colors">
                  {faq.q}
                  <svg class="w-5 h-5 shrink-0 text-tx-secondary transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </summary>
                <p class="px-6 pb-6 text-tx-secondary leading-relaxed">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="py-12 px-6 border-t border-glass-border">
      <p class="max-w-3xl mx-auto text-center text-sm text-tx-secondary leading-relaxed">
        A free tool from <a href="/" class="text-tx-primary hover:text-accent font-medium">Cloudzeta
        Solutions</a>. No ads, no tracking, no account. It stays that way.
        <br class="hidden sm:block" />
        See all <a href="/tools" class="text-tx-primary hover:text-accent font-medium">free tools</a>.
      </p>
    </footer>
  </main>
</Layout>
