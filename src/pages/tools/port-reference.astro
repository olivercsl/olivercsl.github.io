---
/**
 * ============================================================================
 *  DO NOT ADD ANALYTICS, ADS, OR THIRD-PARTY SCRIPTS TO THIS PAGE.
 * ============================================================================
 *  Same commitment as the other tools: no ads, no trackers, works offline.
 *  Any external script makes those published claims false.
 * ============================================================================
 */
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { PortReference } from '../../components/tools/PortReference';

const faqs = [
  {
    "q": "What are well-known, registered and ephemeral ports?",
    "a": "Ports 0 to 1023 are well-known and historically require privileges to bind; 1024 to 49151 are registered for applications; 49152 to 65535 are ephemeral, used by clients as the source port of outgoing connections. Linux commonly uses 32768 to 60999 for ephemeral ports."
  },
  {
    "q": "Why do some services use TCP and others UDP?",
    "a": "TCP gives ordered, reliable delivery at the cost of connection setup, suiting databases, web and mail. UDP is fire-and-forget, suiting DNS queries, clock sync, VoIP media and games, where a late answer is worthless anyway. Some protocols use both, and HTTP/3 moved the web onto UDP via QUIC."
  },
  {
    "q": "Which ports should never be exposed to the internet?",
    "a": "Unauthenticated data and management planes: databases such as 3306, 5432, 6379, 27017 and 9200, SMB on 445, RDP on 3389 without a gateway, the Docker API on 2375, and the kubelet on 10250. These are scanned constantly; reach them over VPNs or private networks instead."
  },
  {
    "q": "Can a service run on a different port than listed?",
    "a": "Yes, these are defaults and conventions, not rules. Anything can listen anywhere, which is why firewalls that identify traffic by port alone are only a first approximation."
  },
  {
    "q": "Does this page look anything up remotely?",
    "a": "No. The table ships with the page, search runs in your browser, and it works offline."
  }
];

const pageUrl = 'https://cloudzeta.solutions/tools/port-reference';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}#app`,
      name: "Cloudzeta Network Port Reference",
      url: pageUrl,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any modern web browser',
      description: "Free searchable reference of common TCP and UDP ports, from databases and message queues to Kubernetes and mail, with practical security notes. No ads, no tracking.",
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: ["Curated common ports rather than the full IANA registry", "Search by number, service name or protocol", "Security notes for the ports that should never face the internet", "Runs offline. Nothing is sent to a server"],
      publisher: { '@type': 'Organization', name: 'Cloudzeta Solutions', url: 'https://cloudzeta.solutions' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cloudzeta.solutions' },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://cloudzeta.solutions/tools' },
        { '@type': 'ListItem', position: 3, name: "Network Port Reference", item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title="Network Port Reference | Common TCP & UDP Ports | Cloudzeta"
  description="Searchable reference of common TCP and UDP ports: databases, message queues, Kubernetes, mail, VPN and more, with security notes. Free, no ads."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navbar minimal client:load />

  <main>
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 px-4 sm:px-6 bg-[radial-gradient(78%_120%_at_50%_-8%,#eef5ff_0%,#ffffff_58%)]">
      <div class="max-w-5xl mx-auto text-center mb-6 md:mb-7">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-tx-primary leading-[1.08]">
          Network Port Reference
        </h1>
      </div>

      <div class="max-w-3xl mx-auto">
        <PortReference client:load />
        <p class="text-base text-tx-secondary text-center text-balance mt-6">
          The ports engineers actually meet, searchable by number, service or protocol.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6 bg-surface border-t border-glass-border">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-12 text-center">
          Port FAQs
        </h2>
        <div class="space-y-3">
          {
            faqs.map((faq) => (
              <details class="group bg-white border border-glass-border rounded-2xl overflow-hidden shadow-sm">
                <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 font-semibold text-tx-primary list-none hover:text-accent transition-colors">
                  {faq.q}
                  <svg class="w-5 h-5 shrink-0 text-tx-secondary transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </summary>
                <p class="px-6 pb-6 text-tx-secondary leading-relaxed">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="py-12 px-6 border-t border-glass-border">
      <p class="max-w-3xl mx-auto text-center text-sm text-tx-secondary leading-relaxed">
        A free tool from <a href="/" class="text-tx-primary hover:text-accent font-medium">Cloudzeta
        Solutions</a>. No ads, no tracking, no account. It stays that way.
        <br class="hidden sm:block" />
        See all <a href="/tools" class="text-tx-primary hover:text-accent font-medium">free tools</a>.
      </p>
    </footer>
  </main>
</Layout>
