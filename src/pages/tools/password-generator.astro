---
/**
 * ============================================================================
 *  DO NOT ADD ANALYTICS, ADS, OR THIRD-PARTY SCRIPTS TO THIS PAGE.
 * ============================================================================
 *  The page states in writing that it carries no ads, no trackers and no
 *  analytics, and invites visitors to verify that in their network tab. It also
 *  invites them to disconnect and confirm it still works. Adding any external
 *  script — including a site-wide analytics snippet rolled out elsewhere —
 *  makes those published claims false and breaks offline use.
 *
 *  If site-wide tracking is introduced later, this route must be excluded.
 *  The generator itself must likewise never transmit, store, or log a password.
 * ============================================================================
 */
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { PasswordGenerator } from '../../components/tools/PasswordGenerator';

const faqs = [
  {
    q: 'How do password generators work?',
    a: 'A password generator picks characters at random from a defined set: letters, digits and symbols. This tool draws that randomness from your browser\'s Web Crypto API, the same cryptographically secure source used to generate TLS keys, and uses rejection sampling so every character in the set is equally likely. The result has no pattern for an attacker to predict, unlike a password a person invents.',
  },
  {
    q: 'Is this password generator free to use?',
    a: 'Yes. The Cloudzeta password generator is completely free, requires no account, and has no usage limits.',
  },
  {
    q: 'Is this password generator safe to use?',
    a: 'Yes. The page is static and the generator runs entirely in your browser. No password is transmitted, stored, or logged. You can confirm this by opening your browser\'s network tab while generating, or by disconnecting from the internet: the tool keeps working offline.',
  },
  {
    q: 'How often should I change my password?',
    a: 'Modern guidance from NIST is to stop rotating passwords on a fixed schedule. Forced expiry pushes people toward predictable variations like Summer2024 then Summer2025. Change a password when you have a reason to: a breach notification, a shared credential, or any suspicion of compromise. A long, unique, randomly generated password can otherwise stay in place.',
  },
  {
    q: 'What are the most common password mistakes?',
    a: 'Reusing one password across sites is the most damaging, because a single breach then unlocks many accounts. Others include building passwords from personal information such as names or birthdays, relying on predictable substitutions like replacing "o" with "0", using short passwords with added complexity instead of longer ones, and sharing credentials over email or chat.',
  },
  {
    q: 'Are the generated passwords sent to your servers?',
    a: 'No. Every password is generated locally in your browser using the Web Crypto API. Nothing is transmitted over the network, written to storage, or logged. You can verify this by opening your browser developer tools and watching the network tab while generating passwords, or by disconnecting from the internet entirely: the tool keeps working.',
  },
  {
    q: 'What makes a password strong?',
    a: 'Length and randomness. A strong password is long (16 characters or more), drawn from a large character set, and generated randomly rather than chosen by a person. Predictable substitutions such as replacing "o" with "0" add almost no real security, because attackers test those patterns first.',
  },
  {
    q: 'What does "bits of entropy" mean?',
    a: 'Entropy measures how many guesses an attacker would need. Each additional bit doubles that number. Below about 45 bits a password is weak against modern hardware; 65 bits is reasonable; above 100 bits is excellent and effectively out of reach of brute force.',
  },
  {
    q: 'Should I use a random password or a passphrase?',
    a: 'Random passwords are shorter and ideal when stored in a password manager. Passphrases are far easier to type and remember, which makes them a good fit for the handful of credentials you must memorise, such as your device login or password manager master password. Both are strong when generated randomly.',
  },
  {
    q: 'Why exclude similar characters?',
    a: 'Characters such as 0 and O, or 1, l and |, are easy to confuse in many fonts. Excluding them helps when a password must be read aloud, typed manually, or transcribed from a screen. It slightly reduces entropy, so increase the length a little to compensate.',
  },
  {
    q: 'How should I store the passwords I generate?',
    a: 'Use a reputable password manager. It lets you keep a unique, long, random password for every account without memorising any of them. Never reuse passwords across services: a breach at one site is the most common way accounts elsewhere get compromised.',
  },
];

const pageUrl = 'https://cloudzeta.solutions/tools/password-generator';

// Dashlane's page ships no structured data at all, so this is cheap
// differentiation: FAQ rich results, a tool listing, and breadcrumbs.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}#app`,
      name: 'Cloudzeta Password Generator',
      url: pageUrl,
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'Any modern web browser',
      browserRequirements: 'Requires JavaScript and the Web Crypto API',
      description:
        'Free browser-based generator for strong random passwords and passphrases. Runs entirely client-side using the Web Crypto API.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: [
        'Random passwords from 4 to 40 characters',
        'Memorable passphrases from an EFF diceware wordlist',
        'Entropy and crack-time strength estimates',
        'Exclude visually similar characters',
        'Runs offline. Nothing is sent to a server',
      ],
      publisher: { '@type': 'Organization', name: 'Cloudzeta Solutions', url: 'https://cloudzeta.solutions' },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumbs`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cloudzeta.solutions' },
        { '@type': 'ListItem', position: 2, name: 'Password Generator', item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title="Free Password Generator | Strong Random Passwords & Passphrases | Cloudzeta"
  description="Generate strong, random passwords and passphrases free. Runs entirely in your browser using the Web Crypto API. Nothing is ever sent to a server. Built by Cloudzeta Solutions, an AWS Advanced Partner."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navbar minimal client:load />

  <main>
    <!-- Tool -->
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 px-4 sm:px-6 bg-[radial-gradient(78%_120%_at_50%_-8%,#eef5ff_0%,#ffffff_58%)]">
      <div class="max-w-5xl mx-auto text-center mb-6 md:mb-7">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-tx-primary leading-[1.08]">
          Free Password Generator
        </h1>
      </div>

      <div class="max-w-2xl lg:max-w-5xl mx-auto">
        <PasswordGenerator client:load />

        <p class="text-base text-tx-secondary text-center text-balance mt-6">
          Strong, random passwords and passphrases that are genuinely hard to crack.
        </p>
      </div>
    </section>

    <!-- What makes a strong password -->
    <section class="py-24 px-6 border-t border-glass-border">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-4 text-center">
          What makes a strong password?
        </h2>
        <p class="text-xl text-tx-secondary text-center mb-14 max-w-2xl mx-auto">
          Strength comes from length and randomness, not from clever-looking substitutions.
        </p>

        <div class="grid md:grid-cols-3 gap-6 items-stretch">
          <div class="bg-white p-7 rounded-2xl border border-glass-border shadow-sm">
            <div class="w-11 h-11 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-tx-primary mb-2">Length beats complexity</h3>
            <p class="text-tx-secondary leading-relaxed">
              Every extra character multiplies the work an attacker must do. A 20-character password
              of only lowercase letters is far stronger than an 8-character one using every symbol.
            </p>
          </div>

          <div class="bg-white p-7 rounded-2xl border border-glass-border shadow-sm">
            <div class="w-11 h-11 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581"
                />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-tx-primary mb-2">True randomness</h3>
            <p class="text-tx-secondary leading-relaxed">
              People are predictable: we favour names, dates, and keyboard patterns. This tool uses
              your browser's cryptographic random number generator, so there is no pattern to exploit.
            </p>
          </div>

          <div class="bg-white p-7 rounded-2xl border border-glass-border shadow-sm">
            <div class="w-11 h-11 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-tx-primary mb-2">Never reused</h3>
            <p class="text-tx-secondary leading-relaxed">
              Reuse is how one breach becomes many. Give every account its own password and store
              them in a password manager rather than trying to remember them.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works / privacy -->
    <section class="py-24 px-6 bg-surface border-y border-glass-border">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 text-xs font-semibold mb-6">
            Privacy by design
          </div>
          <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-6">
            Your passwords never leave your device.
          </h2>
          <p class="text-lg text-tx-secondary leading-relaxed mb-6">
            Most free password generators are funded by ads or an upgrade prompt: third-party
            scripts running on the very page where you generate a secret. This one carries none of
            that. It is a static page with no backend and no analytics, and passwords are produced by
            <code class="text-sm bg-white px-1.5 py-0.5 rounded border border-glass-border">crypto.getRandomValues()</code>,
            the same source browsers use for TLS key material. Don't take our word for it: open your
            network tab, or turn off your connection and watch it keep working.
          </p>
          <ul class="space-y-3">
            {
              [
                'No ads, no trackers, no analytics on this page',
                'No account, no email, nothing to sign up for',
                'Cryptographically secure randomness, never Math.random()',
                'Unbiased sampling, so no character is more likely than another',
                'No network requests. Disconnect your wifi and it still works',
                'Nothing written to cookies, storage, or the URL',
              ].map((item) => (
                <li class="flex items-start gap-3 text-tx-primary">
                  <svg
                    class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="bg-white rounded-2xl border border-glass-border shadow-sm p-7">
          <h3 class="text-lg font-semibold text-tx-primary mb-4">How long should my password be?</h3>
          <div class="space-y-3">
            {
              [
                { len: '8 characters', verdict: 'Cracked in hours', color: 'text-red-600', bar: 'w-[12%] bg-red-500' },
                { len: '12 characters', verdict: 'Cracked in years', color: 'text-amber-600', bar: 'w-[35%] bg-amber-500' },
                { len: '16 characters', verdict: 'Effectively safe', color: 'text-blue-600', bar: 'w-[65%] bg-blue-500' },
                { len: '20+ characters', verdict: 'Out of reach', color: 'text-emerald-600', bar: 'w-full bg-emerald-500' },
              ].map((row) => (
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium text-tx-primary">{row.len}</span>
                    <span class={`font-semibold ${row.color}`}>{row.verdict}</span>
                  </div>
                  <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class={`h-full rounded-full ${row.bar}`} />
                  </div>
                </div>
              ))
            }
          </div>
          <p class="text-xs text-tx-secondary mt-5 leading-relaxed">
            Estimates assume a mixed character set and an offline attack at roughly 10<sup>10</sup>
            guesses per second against a fast hash.
          </p>
        </div>
      </div>
    </section>

    <!-- How to use -->
    <section class="py-24 px-6 border-t border-glass-border">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-4 text-center">
          How to generate a strong password
        </h2>
        <p class="text-xl text-tx-secondary text-center mb-14 max-w-2xl mx-auto">
          Four steps, about ten seconds.
        </p>

        <ol class="grid sm:grid-cols-2 gap-6">
          {
            [
              {
                n: '1',
                t: 'Choose a length',
                d: 'Drag the slider or tap a preset. We recommend at least 16 characters. Use 32 for high-value accounts such as email, banking, and cloud root logins.',
              },
              {
                n: '2',
                t: 'Pick your character types',
                d: 'Keep uppercase, lowercase, digits, and symbols enabled for maximum strength. If a site rejects symbols, switch them off and add a few characters of length instead.',
              },
              {
                n: '3',
                t: 'Check the strength meter',
                d: 'Aim for 100 bits of entropy or more. The meter shows the exact figure alongside an estimated offline crack time, so you are not guessing.',
              },
              {
                n: '4',
                t: 'Copy and store it safely',
                d: 'Copy the password straight into a password manager. Never reuse it on another site, and never send it over email or chat.',
              },
            ].map((step) => (
              <li class="bg-white p-7 rounded-2xl border border-glass-border shadow-sm flex gap-5">
                <span class="w-10 h-10 shrink-0 rounded-xl bg-blue-50 text-blue-600 font-bold flex items-center justify-center">
                  {step.n}
                </span>
                <div>
                  <h3 class="text-lg font-semibold text-tx-primary mb-2">{step.t}</h3>
                  <p class="text-tx-secondary leading-relaxed">{step.d}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-12 text-center">
          Password generator FAQs
        </h2>
        <div class="space-y-3">
          {
            faqs.map((faq) => (
              <details class="group bg-white border border-glass-border rounded-2xl overflow-hidden shadow-sm">
                <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 font-semibold text-tx-primary list-none hover:text-accent transition-colors">
                  {faq.q}
                  <svg
                    class="w-5 h-5 shrink-0 text-tx-secondary transition-transform group-open:rotate-45"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </summary>
                <p class="px-6 pb-6 text-tx-secondary leading-relaxed">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Attribution only. No call to action by design: this page asks nothing
         of the visitor, which is the whole point of the tool. -->
    <footer class="py-12 px-6 border-t border-glass-border">
      <p class="max-w-3xl mx-auto text-center text-sm text-tx-secondary leading-relaxed">
        A free tool from <a href="/" class="text-tx-primary hover:text-accent font-medium">Cloudzeta
        Solutions</a>. No ads, no tracking, no account. It stays that way.
        <br class="hidden sm:block" />
        See all <a href="/tools" class="text-tx-primary hover:text-accent font-medium">free tools</a>.
      </p>
    </footer>
  </main>
</Layout>
