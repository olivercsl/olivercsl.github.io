---
/**
 * ============================================================================
 *  DO NOT ADD ANALYTICS, ADS, OR THIRD-PARTY SCRIPTS TO THIS PAGE.
 * ============================================================================
 *  Same commitment as the other tools: no ads, no trackers, works offline.
 *  Any external script makes those published claims false.
 * ============================================================================
 */
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { LittlesLaw } from '../../components/tools/LittlesLaw';

const faqs = [
  {
    "q": "What is Little's Law?",
    "a": "L = lambda x W: the average number of requests in a system equals their arrival rate multiplied by the average time each spends inside. It holds for any stable system regardless of arrival patterns or queueing discipline, which is what makes it so useful."
  },
  {
    "q": "How do I use it to size a thread pool or connection pool?",
    "a": "Multiply expected throughput by expected latency. At 200 requests per second with 150ms in the system, you average 30 requests in flight, so a pool of roughly 30 is the floor. Add headroom for bursts and latency spikes, because at the moment latency doubles, so does the concurrency you need."
  },
  {
    "q": "What does it predict when latency degrades?",
    "a": "Trouble compounding. If throughput stays constant and latency rises, in-flight work rises proportionally, which consumes more workers and memory, which often raises latency further. Many cascading failures are this loop; bounded queues and load shedding are the brakes."
  },
  {
    "q": "Which units should I use?",
    "a": "Any, as long as they agree. The calculator uses requests per second and seconds, so concurrency comes out dimensionless. Milliseconds work too if you divide by 1000 first."
  },
  {
    "q": "Is anything sent to a server?",
    "a": "No. The arithmetic runs in your browser and the page works offline."
  }
];

const pageUrl = 'https://cloudzeta.solutions/tools/littles-law-calculator';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}#app`,
      name: "Cloudzeta Little's Law Calculator",
      url: pageUrl,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any modern web browser',
      description: "Free Little's Law calculator for capacity planning. Solve concurrency, throughput and latency from the other two, and convert request rates across windows. No ads, no tracking.",
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: ["Solve L, lambda or W from the other two", "Plain-language reading of the result", "Request rate converted across second, minute, hour, day and month", "Runs offline. Nothing is sent to a server"],
      publisher: { '@type': 'Organization', name: 'Cloudzeta Solutions', url: 'https://cloudzeta.solutions' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cloudzeta.solutions' },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://cloudzeta.solutions/tools' },
        { '@type': 'ListItem', position: 3, name: "Little's Law Calculator", item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title="Little's Law Calculator | Concurrency & Throughput | Cloudzeta"
  description="Solve L = lambda x W for concurrency, throughput or latency, and convert request rates across time windows. Free capacity planning math, no ads."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navbar minimal client:load />

  <main>
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 px-4 sm:px-6 bg-[radial-gradient(78%_120%_at_50%_-8%,#eef5ff_0%,#ffffff_58%)]">
      <div class="max-w-5xl mx-auto text-center mb-6 md:mb-7">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-tx-primary leading-[1.08]">
          Little's Law Calculator
        </h1>
      </div>

      <div class="max-w-3xl mx-auto">
        <LittlesLaw client:load />
        <p class="text-base text-tx-secondary text-center text-balance mt-6">
          The one-line law behind most capacity planning, solved for whichever variable you are missing.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6 bg-surface border-t border-glass-border">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-tx-primary mb-12 text-center">
          Little's Law FAQs
        </h2>
        <div class="space-y-3">
          {
            faqs.map((faq) => (
              <details class="group bg-white border border-glass-border rounded-2xl overflow-hidden shadow-sm">
                <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 font-semibold text-tx-primary list-none hover:text-accent transition-colors">
                  {faq.q}
                  <svg class="w-5 h-5 shrink-0 text-tx-secondary transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </summary>
                <p class="px-6 pb-6 text-tx-secondary leading-relaxed">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="py-12 px-6 border-t border-glass-border">
      <p class="max-w-3xl mx-auto text-center text-sm text-tx-secondary leading-relaxed">
        A free tool from <a href="/" class="text-tx-primary hover:text-accent font-medium">Cloudzeta
        Solutions</a>. No ads, no tracking, no account. It stays that way.
        <br class="hidden sm:block" />
        See all <a href="/tools" class="text-tx-primary hover:text-accent font-medium">free tools</a>.
      </p>
    </footer>
  </main>
</Layout>
